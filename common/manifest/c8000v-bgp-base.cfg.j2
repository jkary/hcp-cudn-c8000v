! c8000v base BGP configuration for CUDN routing between hub and spoke clusters
! Generated from vars.yaml — do not edit directly

router bgp {{ c8000v_asn }}
 bgp router-id {{ c8000v_host }}
 bgp log-neighbor-changes
 !
 ! Hub cluster nodes (AS {{ hub_asn }}) on Gi1 (172.16.252.0/24)
{% for i in range(hub_node_ips | length) %}
 neighbor {{ hub_node_ips[i] }} remote-as {{ hub_asn }}
 neighbor {{ hub_node_ips[i] }} description {{ hub_node_descriptions[i] }}
 neighbor {{ hub_node_ips[i] }} next-hop-self
{% endfor %}
{% if spoke_node_ips is defined %}
 !
 ! Spoke cluster nodes (AS {{ spoke_asn }}) on Gi2 (172.16.253.0/24)
{% for i in range(spoke_node_ips | length) %}
 neighbor {{ spoke_node_ips[i] }} remote-as {{ spoke_asn }}
 neighbor {{ spoke_node_ips[i] }} description {{ spoke_node_descriptions[i] }}
 neighbor {{ spoke_node_ips[i] }} next-hop-self
{% endfor %}
{% endif %}
 !
 address-family ipv4 unicast
{% for ip in hub_node_ips %}
  neighbor {{ ip }} activate
{% endfor %}
{% for ip in spoke_node_ips | default([]) %}
  neighbor {{ ip }} activate
{% endfor %}
  maximum-paths {{ hub_node_ips | length }}
 exit-address-family
!
end
